{
  "name": "class-reminder-app",
  "version": "1.0.0",
  "description": "Never miss a class again - smart calendar reminders for students",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "electron",
    "calendar",
    "reminders",
    "student",
    "classes"
  ],
  "author": "Student Assistant",
  "license": "MIT",
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3"
  },
  "build": {
    "appId": "com.studentassistant.classreminder",
    "productName": "Class Reminder",
    "mac": {
      "category": "public.app-category.education",
      "icon": "icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!node_modules/electron-builder/**/*"
    ],
    "dmg": {
      "title": "Class Reminder",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
