{
  "name": "student-assistant-pro",
  "version": "3.0.0",
  "description": "Complete student productivity app - classes, assignments, exams, notes, timer and more",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "electron",
    "student",
    "calendar",
    "reminders",
    "productivity",
    "education"
  ],
  "author": "Student Assistant",
  "license": "MIT",
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.studentassistant.pro",
    "productName": "Student Assistant Pro",
    "mac": {
      "category": "public.app-category.education",
      "target": ["dmg", "zip"]
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!node_modules/electron-builder/**/*"
    ]
  }
}
